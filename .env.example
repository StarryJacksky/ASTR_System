# ASTR 环境变量模板
# 落点：P0-T02 → 仓库根 .env.example（复制为 .env 填真实值；.env 必须进 .gitignore，永不提交）
# 智囊团 6 家：Anthropic / OpenAI / Google Gemini / xAI(Grok) / DeepSeek / Qwen(DashScope)

# —— 大厂 API keys（LiteLLM 自动读取这些标准变量名，填上即可）——
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=          # 云 Qwen（阿里 DashScope 控制台获取）

# 各家 key 获取地址（开工时去拿）：
#   Anthropic  https://console.anthropic.com/        OpenAI   https://platform.openai.com/api-keys
#   Gemini     https://aistudio.google.com/apikey     xAI      https://console.x.ai/
#   DeepSeek   https://platform.deepseek.com/         Qwen     https://dashscope.console.aliyun.com/

# —— 本地推理与数据目录 ——
ASTR_DATA_DIR=D:/ASTR
LOCAL_LLM_BASE=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=qwen3-8b

# —— 预算闸与 MoA 策略（03 §4 / §4 末）——
ASTR_DAILY_BUDGET_USD=5
MOA_SHORT_MAX_CHARS=20      # 消息 < 此长度：只走 1 路（emotion_analysis@cheap）省钱
MOA_LONG_MIN_CHARS=200      # 消息 > 此长度 或 学术任务：四路全开 @balanced

# —— 平台（P1-W6 起按需填）——
TELEGRAM_BOT_TOKEN=
# QQ 走 NapCat：key 在 NapCat WebUI 配置，AstrBot aiocqhttp 适配器连接，无需在此填
